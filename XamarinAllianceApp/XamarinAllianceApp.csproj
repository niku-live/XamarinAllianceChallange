<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>netstandard2.0</TargetFramework>
    <ProjectGuid>{3AFA591D-C115-4AC9-9519-F788373ECDE9}</ProjectGuid>
    <RootNamespace>XamarinAllianceApp</RootNamespace>
    <AssemblyName>XamarinAllianceApp</AssemblyName>
    <!-- Keep existing AssemblyInfo.cs; disable SDK auto-generation to avoid duplicate attribute errors -->
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <!-- AssemblyVersion wildcard (1.0.*) requires non-deterministic builds -->
    <Deterministic>false</Deterministic>
  </PropertyGroup>

  <ItemGroup>
    <!-- Explicitly embed Xamarin.Forms XAML so it is available to XamlLoader at runtime -->
    <EmbeddedResource Include="**\*.xaml" />
    <EmbeddedResource Include="characters.json" />
  </ItemGroup>

  <ItemGroup>
    <!-- Xamarin.Forms 3.0+ is the first release with netstandard2.0 support -->
    <PackageReference Include="Microsoft.Data.OData" Version="5.8.4" />
    <PackageReference Include="Xamarin.Forms" Version="3.0.0.530893" />
    <!-- Azure Mobile Client 4.x adds netstandard support; replaces 3.1.0 PCL-only build -->
    <PackageReference Include="Microsoft.Azure.Mobile.Client" Version="4.2.0" />
    <!-- WindowsAzure.Storage 8.x ships a netstandard1.0 lib, compatible with netstandard2.0 -->
    <PackageReference Include="WindowsAzure.Storage" Version="8.1.4" />
    <PackageReference Include="Newtonsoft.Json" Version="13.0.4" />
    <!-- Dropped: Microsoft.Bcl, Microsoft.Bcl.Build, Microsoft.Net.Http, NETStandard.Library,  -->
    <!--          and all System.* primitive packages — all built into netstandard2.0             -->
  </ItemGroup>

</Project>